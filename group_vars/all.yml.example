# Proxmox API
pve_api_host: "192.168.56.37"
pve_api_user: "ansible@pve"
pve_api_token_id: "k8s-lab"
pve_api_token_secret: "CHANGE_ME_API_TOKEN_SECRET"
pve_validate_certs: false

# Proxmox target
pve_node: "pve"
pve_storage: "local-lvm"

# SSH target for Proxmox CLI operations such as qm resize
pve_ssh_host_alias: "pve"

# Clone source template
pve_template_vmid: 98000

# Cloud-init common settings
cloud_init_user: "ansible"
cloud_init_ssh_key: "{{ lookup('file', lookup('env', 'HOME') + '/.ssh/id_rsa.pub') }}"
k8s_gateway: "192.168.56.2"
k8s_dns: "192.168.56.122"

# Guest OS disk resize settings
guest_root_disk: "/dev/sda"
guest_root_partition_number: 1
guest_root_partition: "/dev/sda1"

# Kubernetes lab VMs
k8s_vms:
  - name: k8s-control01
    vmid: 98129
    ip: "192.168.56.129"
    prefix: 24
    cores: 2
    memory: 4096
    disk_size: "40G"

  - name: k8s-worker01
    vmid: 98127
    ip: "192.168.56.127"
    prefix: 24
    cores: 2
    memory: 4096
    disk_size: "40G"

  - name: k8s-worker02
    vmid: 98128
    ip: "192.168.56.128"
    prefix: 24
    cores: 2
    memory: 4096
    disk_size: "40G"


# Kubernetes package settings
kubernetes_version_minor: "v1.34"

# Kernel modules for Kubernetes networking
k8s_kernel_modules:
  - overlay
  - br_netfilter

# sysctl settings for Kubernetes networking
k8s_sysctl_settings:
  net.bridge.bridge-nf-call-iptables: 1
  net.bridge.bridge-nf-call-ip6tables: 1
  net.ipv4.ip_forward: 1

# Kubernetes cluster settings
k8s_pod_network_cidr: "10.244.0.0/16"
k8s_control_plane_endpoint: "192.168.56.129"

# Flannel CNI
flannel_manifest_url: "https://github.com/flannel-io/flannel/releases/latest/download/kube-flannel.yml"
flannel_manifest_path: "/tmp/kube-flannel.yml"

# Demo web application
demo_app_namespace: "demo-web"
demo_app_name: "demo-nginx"
demo_app_replicas: 3
demo_app_image: "nginx:stable"
demo_app_service_name: "demo-nginx-service"
demo_app_node_port: 30080

# MetalLB
metallb_manifest_url: "https://raw.githubusercontent.com/metallb/metallb/v0.14.9/config/manifests/metallb-native.yaml"
metallb_namespace: "metallb-system"
metallb_ip_pool_name: "k8s-lab-pool"
metallb_l2_advertisement_name: "k8s-lab-l2"
metallb_address_pool: "192.168.56.249-192.168.56.251"
